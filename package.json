{
  "name": "bioassaycraft",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.18.0",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build && node scripts/copy-static-site.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src scripts tests vite.config.js eslint.config.js prettier.config.js",
    "format": "prettier --check \"src/**/*.{js,vue,css}\" \"scripts/**/*.mjs\" \"tests/**/*.mjs\" \"*.{js,json,html}\"",
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run"
  },
  "dependencies": {
    "@floating-ui/vue": "^2.0.0",
    "d3": "^7.9.0",
    "motion": "^12.42.2",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "vite": "^8.1.3",
    "vitest": "^3.2.6",
    "wrangler": "^4.107.0"
  }
}
